# =============================================================================
# TechBuddy — example environment variables
# =============================================================================
# Copy this file to apps/api/.env and fill in real values.
# NEVER commit a real .env file. NEVER put secrets in the mobile or desktop apps.
# =============================================================================

# --- Anthropic / Claude ------------------------------------------------------
# Get from https://console.anthropic.com — used only by the backend.
ANTHROPIC_API_KEY=sk-ant-...

# Default model for Buddy chat. Sonnet is the cost/quality sweet spot for triage.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database (Neon Postgres) ------------------------------------------------
# Get from https://neon.tech — your "techbuddy-dev" project's connection string.
DATABASE_URL=postgresql://USER:PASS@HOST.neon.tech/techbuddy?sslmode=require

# --- Backend ----------------------------------------------------------------
PORT=4000
NODE_ENV=development

# Used to sign session JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-byte-random-hex-string

# CORS origins allowed to call the API in dev. Comma-separated.
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# --- Mobile / Web (these live in apps/mobile/.env and apps/web/.env.local) --
# The PUBLIC_ prefix means it's safe to bundle into the client.
# Point this at your local API in dev; replace with your prod URL later.
PUBLIC_API_URL=http://localhost:4000

# --- Image storage (Phase 2 — leave blank until needed) ----------------------
# We'll wire up either S3 or Cloudflare R2 when we add the photo intake feature.
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
