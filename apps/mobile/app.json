{
  "expo": {
    "name": "TechBuddy",
    "slug": "techbuddy",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "techbuddy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tariq.techbuddy"
    },
    "android": {
      "package": "com.tariq.techbuddy",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2A6CF6",
          "dark": {
            "backgroundColor": "#2A6CF6"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "TechBuddy needs camera access so you can show Buddy what's on your screen.",
          "photosPermission": "TechBuddy needs access to your photos so you can pick a screenshot to send to Buddy."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "TechBuddy needs microphone access so you can speak to Buddy instead of typing.",
          "speechRecognitionPermission": "TechBuddy needs speech recognition so it can turn your spoken words into text for Buddy."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "techbuddy-mobile",
          "organization": "teekaylabs"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "658f1af3-5e35-430a-897c-c4f54de441b0"
      }
    }
  }
}
