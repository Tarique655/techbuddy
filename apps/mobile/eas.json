{
  "cli": {
    "version": ">= 18.9.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.11.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://techbuddy-api.onrender.com",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "SENTRY_ALLOW_FAILURE": "true"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "node": "22.11.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://techbuddy-api.onrender.com",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "SENTRY_ALLOW_FAILURE": "true"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "node": "22.11.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://techbuddy-api.onrender.com",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "SENTRY_ALLOW_FAILURE": "true"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
