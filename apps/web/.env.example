# Where the family portal calls the backend. Read by:
#   - middleware.ts (no — middleware doesn't call the API directly)
#   - app/api/* route handlers (yes — they proxy to the Fastify API)
# Public-prefixed for legacy reasons (it used to be read client-side
# pre-Stage-C). After Stage E we can rename to API_URL since nothing
# client-side needs it anymore.
NEXT_PUBLIC_API_URL=https://techbuddy-api.onrender.com

# HMAC secret for verifying the `tb_session` cookie's JWT signature.
# MUST exactly match the API's JWT_SECRET — they sign and verify the
# same tokens. Read by middleware.ts (Edge runtime) and by the Sentry
# tunnel route. Generate via:
#   openssl rand -base64 48
# In dev (NODE_ENV=development), the file falls back to a dev-only
# string that's also hard-coded in apps/api/src/lib/env.ts. In prod
# both Render and Vercel must have the same JWT_SECRET set.
# JWT_SECRET=

# Optional. Defaults to "techbuddy-api". Must match the API's
# JWT_ISSUER if you ever override it there.
# JWT_ISSUER=techbuddy-api
