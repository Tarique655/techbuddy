{
  "name": "techbuddy",
  "version": "0.0.1",
  "private": true,
  "description": "TechBuddy — AI-powered tech support for seniors. Monorepo containing the senior mobile app, desktop companion, family web portal, and backend API.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0 <25",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:mobile": "pnpm --filter @techbuddy/mobile dev",
    "dev:desktop": "pnpm --filter @techbuddy/desktop dev",
    "dev:web": "pnpm --filter @techbuddy/web dev",
    "dev:api": "pnpm --filter @techbuddy/api dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@sentry/cli-linux-x64",
      "@sentry/cli-linux-arm64",
      "@sentry/cli-linux-arm",
      "@sentry/cli-linux-i686",
      "@sentry/cli-darwin",
      "@sentry/cli-win32-x64",
      "@sentry/cli-win32-i686",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
